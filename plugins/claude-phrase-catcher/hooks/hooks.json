{
    "hooks": {
      "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/ensure_python.sh\""
          }
        ]
      }
    ],
    "MessageDisplay": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"$(cat ${CLAUDE_PLUGIN_ROOT}/scripts/.python_bin) ${CLAUDE_PLUGIN_ROOT}/scripts/catchPhrase.py\""
          }
        ]
      }
    ]
  }
}